generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Bracelet {
  id            String       @id @default(uuid())
  certNo        String       @unique
  /// 吊牌条形码内容（与 certNo 可不同，供扫码枪识别）
  barcodeValue  String?
  /// Excel A-N 基础列（与辅助出库软件一致，仅此部分同步 Excel）
  arrivalDate   String?
  batch         String?
  qty           Int          @default(1)
  category      String?
  ringSize      String?
  cost          String?
  /// 吊牌「售价」行文字（如 售价:9000元），与 Excel 成本/实际售价无关
  labelPrice    String?
  remark        String?
  orderNo       String?
  returnDate    String?
  soldDate      String?
  actualPrice   String?
  salesPerson   String?
  salesChannel  String?
  excelRow      Int?
  excelSheet    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  detail        BraceletDetail?
  mediaAssets   MediaAsset[]
  operationLogs OperationLog[]
}

/// SQL 专有扩展信息（图片/视频在 MediaAsset，不进 Excel）
model BraceletDetail {
  id           String   @id @default(uuid())
  braceletId   String   @unique
  bracelet     Bracelet @relation(fields: [braceletId], references: [id], onDelete: Cascade)
  description  String?
  material     String?
  jadeGrade    String?
  weightGram   String?
  origin       String?
  color        String?
  flawNotes    String?
  internalNote String?
  tags         String?
  extraJson    String   @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MediaAsset {
  id          String   @id @default(uuid())
  braceletId  String
  bracelet    Bracelet @relation(fields: [braceletId], references: [id], onDelete: Cascade)
  type        String
  filename    String
  path        String
  thumbPath   String?
  mimeType        String?
  sizeBytes       Int      @default(0)
  watermarkBaked  Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model OperationLog {
  id            String   @id @default(uuid())
  braceletId    String
  bracelet      Bracelet @relation(fields: [braceletId], references: [id], onDelete: Cascade)
  certNo        String
  opType        String
  snapshotJson  String
  resultJson    String?
  excelSynced   Boolean  @default(false)
  excelSyncMsg  String?
  reverted      Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model LabelTemplate {
  id          String   @id @default(uuid())
  name        String   @unique @default("default")
  widthMm     Float    @default(50)
  heightMm    Float    @default(30)
  fieldsJson  String
  barcodeType String   @default("CODE128")
  isDefault   Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

model AppSettings {
  id    String @id @default("singleton")
  json  String @default("{}")
}

/// 用户行为审计（登录、点击、页面、API 等），仅 fanfan 可查看
model UserActivityLog {
  id         String   @id @default(uuid())
  username   String?
  category   String
  action     String
  path       String?
  detailJson String   @default("{}")
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([username])
  @@index([category])
}

/// 本地助手注册机器
model AgentMachine {
  id           String      @id @default(uuid())
  name         String
  machineCode  String      @unique
  status       String      @default("offline")
  lastSeenAt   DateTime?
  version      String?
  ip           String?
  capabilities String      @default("[]")
  tokenHash    String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  tasks        AgentTask[]

  @@index([status])
  @@index([lastSeenAt])
}

/// 本地助手任务队列
model AgentTask {
  id           String       @id @default(uuid())
  machineId    String?
  machine      AgentMachine? @relation(fields: [machineId], references: [id], onDelete: SetNull)
  type         String
  payloadJson  String       @default("{}")
  status       String       @default("pending")
  resultJson   String?
  errorMessage String?
  retryCount   Int          @default(0)
  maxRetries   Int          @default(3)
  createdAt    DateTime     @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?

  @@index([status])
  @@index([machineId])
  @@index([createdAt])
}

/// 各子模块运行状态快照
model SystemModuleStatus {
  id         String   @id @default(uuid())
  moduleKey  String   @unique
  moduleName String
  status     String   @default("unknown")
  message    String?
  lastOkAt   DateTime?
  lastErrorAt DateTime?
  detailJson String   @default("{}")
  updatedAt  DateTime @updatedAt
}

/// 千帆中转状态快照（由本地助手或文件读取同步）
model QianfanRelayStatus {
  id                  String   @id @default("singleton")
  running             Boolean  @default(false)
  qianfanReady        Boolean  @default(false)
  listenerReady       Boolean  @default(false)
  wechatReady         Boolean  @default(false)
  attachedShopCount   Int      @default(0)
  expectedShopCount   Int      @default(4)
  lastBuyerMessageAt  DateTime?
  lastWechatNotifyAt  DateTime?
  lastWsFrameAt       DateTime?
  lastError           String?
  detailJson          String   @default("{}")
  updatedAt           DateTime @updatedAt
}

/// 千帆买家消息 / 通知记录
model QianfanRelayMessage {
  id                   String    @id @default(uuid())
  replyId              Int?
  shopName             String?
  buyerNick            String?
  appCid               String?
  receiverAppUidsJson  String    @default("[]")
  text                 String?
  source               String?
  notifyStatus         String?
  replyStatus          String?
  errorMessage         String?
  createdAt            DateTime  @default(now())
  notifiedAt           DateTime?
  repliedAt            DateTime?

  @@index([createdAt])
  @@index([buyerNick])
  @@index([notifyStatus])
}

/// 统一上传媒体记录
model UploadedMedia {
  id         String   @id @default(uuid())
  bizType    String?
  bizId      String?
  fileName   String
  mimeType   String?
  url        String?
  localPath  String?
  size       Int      @default(0)
  sha256     String?
  uploadedBy String?
  createdAt  DateTime @default(now())

  @@index([bizType, bizId])
  @@index([createdAt])
}

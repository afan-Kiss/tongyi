{
  "name": "tongyi-operations-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/server",
    "apps/xiangyu"
  ],
  "scripts": {
    "dev": "concurrently -k --names web,server -c \"#ff2442,#0ea5e9\" \"npm run dev -w @jade/web\" \"npm run dev -w @jade/server\"",
    "dev:web": "npm run dev -w @jade/web",
    "dev:server": "npm run dev -w @jade/server",
    "build": "npm run build:web && npm run build:server",
    "build:web": "npm run build -w @jade/web",
    "build:server": "npm run build -w @jade/server",
    "start": "cross-env NODE_ENV=production npm run start -w @jade/server",
    "start:all": "node scripts/supervisor.js",
    "restart": "node scripts/restart.js",
    "db:generate": "npm run db:generate -w @jade/server",
    "db:migrate": "npm run db:migrate:deploy -w @jade/server",
    "local-agent": "node scripts/local-agent.js",
    "import:legacy-accounting": "node scripts/import-legacy-accounting.js",
    "import:legacy-live": "node scripts/import-legacy-live-analysis.js",
    "check:deploy": "node scripts/check-before-deploy.js",
    "check:valid-revenue": "node scripts/check-valid-revenue-rules.js",
    "setup:admin": "node scripts/setup-admin.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3"
  }
}

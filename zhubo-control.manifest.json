{
  "manifestVersion": 1,
  "name": "统一经营台 / 和田玉统一经营系统",
  "code": "tongyi-operations",
  "category": "统一经营",
  "gitRemote": "https://github.com/afan-Kiss/tongyi",
  "localPath": "E:\\我的软件源码\\tongyi",
  "desktopStartCommand": "npm run dev",
  "localWebUrl": "http://127.0.0.1:5173",
  "localHealthUrl": "http://127.0.0.1:1212/api/health",
  "healthType": "http",
  "ports": [
    1212,
    5173,
    1213,
    1214,
    1215,
    1216,
    1217,
    1218
  ],
  "services": [
    {
      "name": "server",
      "command": "npm run dev:server",
      "port": 1212,
      "healthUrl": "http://127.0.0.1:1212/api/health"
    },
    {
      "name": "web",
      "command": "npm run dev:web",
      "port": 5173,
      "webUrl": "http://127.0.0.1:5173"
    }
  ],
  "control": {
    "enabled": true,
    "showInDesktop": true,
    "cookieMode": "pending",
    "notes": "统一经营台 monorepo，含祥钰、千帆、记账、主播分析等模块入口"
  },
  "riskLevel": "medium"
}
